# ── Frontend environment variables ───────────────────────────────────────────
# Copy to .env.local for local development (never commit .env.local)
# VITE_ prefix is required for Vite to expose variables to the browser

# URL of the FastAPI backend (no trailing slash)
# Local dev: http://localhost:8000  |  Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# Must match INTERNAL_API_KEY in api/.env
VITE_INTERNAL_API_KEY=your-internal-api-key-here
