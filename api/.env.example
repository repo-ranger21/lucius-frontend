# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── AbuseIPDB ─────────────────────────────────────────────────────────────────
# Found in: abuseipdb.com → Account → API
ABUSEIPDB_API_KEY=your-abuseipdb-key

# ── Wordfence ─────────────────────────────────────────────────────────────────
# Found in: wordfence.com/intelligence → API Access
WORDFENCE_API_KEY=your-wordfence-key

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-256-bit-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-app.pages.dev,http://localhost:5173

# ── API ───────────────────────────────────────────────────────────────────────
API_ENV=development
INTERNAL_API_KEY=your-internal-api-key-here
